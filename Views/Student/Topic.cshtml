@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Đề tài";
    var group = Model as CapstoneReviewTool.Entities.CapstoneGroup;
    var topics = ViewBag.Topics as List<CapstoneReviewTool.Entities.Topic> ?? new List<CapstoneReviewTool.Entities.Topic>();
    var selectedTopic = ViewBag.SelectedTopic as CapstoneReviewTool.Entities.Topic;
    var isLeader = group != null && group.LeaderId == User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content (Topic Details or Form) -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800 mb-2">Đề tài</h2>
                    <p class="text-gray-500 text-sm">Đăng ký và theo dõi trạng thái đề tài của nhóm</p>
                </div>
                @if (isLeader)
                {
                    <button onclick="document.getElementById('createTopicModal').classList.remove('hidden')" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors font-medium flex items-center gap-2 shadow-lg shadow-primary/30">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Tạo đề tài mới
                    </button>
                }
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="bg-green-50 text-green-600 p-4 rounded-xl border border-green-100 flex items-center gap-3 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 text-red-600 p-4 rounded-xl border border-red-100 flex items-center gap-3 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    @TempData["Error"]
                </div>
            }

            @if (group == null)
            {
                <div class="text-center py-10 bg-gray-50 rounded-xl border border-dashed border-gray-300">
                    <p class="text-gray-500 mb-4">Bạn chưa có nhóm. Vui lòng tạo nhóm trước khi đăng ký đề tài.</p>
                    <a asp-action="MyGroup" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Đến trang Quản lý nhóm</a>
                </div>
            }
            else if (topics.Count == 0)
            {
                <div class="text-center py-10 bg-gray-50 rounded-xl border border-dashed border-gray-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <p class="text-gray-500 mb-4">Chưa có đề tài nào. Hãy tạo đề tài đầu tiên của bạn!</p>
                    @if (isLeader)
                    {
                        <button onclick="document.getElementById('createTopicModal').classList.remove('hidden')" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Tạo đề tài mới</button>
                    }
                    else
                    {
                        <p class="text-gray-400 text-sm">Vui lòng liên hệ nhóm trưởng để tạo đề tài.</p>
                    }
                </div>
            }
            else if (selectedTopic == null)
            {
                <div class="text-center py-10">
                    <p class="text-gray-500">Vui lòng chọn một đề tài để xem chi tiết.</p>
                </div>
            }
            else
            {
                <!-- Topic Details -->
                <div class="bg-orange-50 rounded-xl p-6 border border-orange-100 mb-6">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-orange-100 text-primary rounded-lg flex items-center justify-center shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <div class="flex justify-between items-start">
                                <h3 class="text-xl font-bold text-gray-900 leading-tight mb-2">@selectedTopic.Name</h3>
                                <span class="px-3 py-1 text-xs font-semibold rounded-full 
                                    @(selectedTopic.Status == "Approved" ? "bg-green-100 text-green-700" : 
                                      selectedTopic.Status == "Submitted" ? "bg-blue-100 text-blue-700" : 
                                      selectedTopic.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                      selectedTopic.Status == "Revision" ? "bg-yellow-100 text-yellow-700" : "bg-gray-100 text-gray-700")">
                                    @selectedTopic.Status
                                </span>
                            </div>
                            
                            <p class="text-gray-600 mb-4 whitespace-pre-line">@selectedTopic.Description</p>
                            
                            <div class="grid grid-cols-2 gap-4 text-sm mb-4">
                                <div>
                                    <span class="text-gray-500 block">Lĩnh vực</span>
                                    <span class="font-medium text-gray-800">@selectedTopic.Field</span>
                                </div>
                                <div>
                                    <span class="text-gray-500 block">Thời gian gửi</span>
                                    <span class="font-medium text-gray-800">@(selectedTopic.SubmittedDate?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa gửi")</span>
                                </div>
                            </div>
                             
                            @if (!string.IsNullOrEmpty(selectedTopic.RepoLink))
                            {
                                <div class="mb-4">
                                    <span class="text-gray-500 block text-sm">Repository</span>
                                    <a href="@selectedTopic.RepoLink" target="_blank" class="text-primary hover:underline flex items-center gap-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                        </svg>
                                        @selectedTopic.RepoLink
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                @if (isLeader)
                {
                    @if (selectedTopic.Status == "Draft" || selectedTopic.Status == "Revision")
                    {
                        <div class="flex justify-end gap-3">
                            <button onclick="document.getElementById('editTopicModal').classList.remove('hidden')" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Chỉnh sửa
                            </button>
                            @if (selectedTopic.Status == "Draft")
                            {
                                <form asp-action="DeleteTopic" method="post" onsubmit="return confirm('Bạn chắc chắn muốn xóa đề tài này? Hành động này không thể hoàn tác.');" class="inline">
                                    <input type="hidden" name="topicId" value="@selectedTopic.Id" />
                                    <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors font-medium flex items-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        Xóa đề tài
                                    </button>
                                </form>
                            }
                            <form asp-action="SubmitTopic" method="post" class="inline">
                                <input type="hidden" name="topicId" value="@selectedTopic.Id" />
                                <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors font-medium shadow-lg shadow-primary/30 flex items-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                    </svg>
                                    Gửi đề tài
                                </button>
                            </form>
                        </div>
                    }
                    @if (selectedTopic.Status == "Approved")
                    {
                        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                            <div class="flex items-center gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <div>
                                    <p class="text-green-800 font-medium text-sm">Đề tài đã được duyệt</p>
                                    <p class="text-green-600 text-xs mt-1">Bạn có thể đăng ký slot bảo vệ ngay bây giờ.</p>
                                    <a asp-action="SlotRegistration" class="mt-2 inline-block px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors text-sm font-medium">
                                        Đăng ký Slot →
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                    else if (selectedTopic.Status == "Rejected")
                    {
                        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                            <div class="flex items-center gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <div class="flex-1">
                                    <p class="text-red-800 font-medium text-sm">Đề tài đã bị từ chối</p>
                                    <p class="text-red-600 text-xs mt-1">Vui lòng xem lý do từ chối trong mô tả đề tài và chỉnh sửa lại.</p>
                                    <div class="mt-3 flex gap-2">
                                        <button onclick="document.getElementById('editTopicModal').classList.remove('hidden')" class="px-4 py-2 bg-white border border-red-300 text-red-700 rounded-lg hover:bg-red-50 transition-colors text-sm font-medium">
                                            Chỉnh sửa lại
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center">
                        <p class="text-gray-600 text-sm">Chỉ nhóm trưởng mới có thể thực hiện các thao tác với đề tài.</p>
                    </div>
                }
            }
        </div>
    </div>
    
    <!-- Sidebar (Right) -->
    <div class="space-y-6">
        <!-- Topics List -->
        @if (group != null && topics.Count > 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="font-bold text-gray-800 mb-4">Danh sách đề tài</h3>
                <div class="space-y-2">
                    @foreach (var topic in topics)
                    {
                        <a asp-action="Topic" asp-route-topicId="@topic.Id" class="block p-3 rounded-lg border @(selectedTopic?.Id == topic.Id ? "border-primary bg-primary/5" : "border-gray-200 hover:border-gray-300 hover:bg-gray-50") transition-colors">
                            <div class="flex justify-between items-start">
                                <div class="flex-1">
                                    <p class="font-medium text-gray-900 text-sm mb-1">@topic.Name</p>
                                    <p class="text-xs text-gray-500">@topic.Field</p>
                                </div>
                                <span class="px-2 py-1 text-xs font-semibold rounded-full 
                                    @(topic.Status == "Approved" ? "bg-green-100 text-green-700" : 
                                      topic.Status == "Submitted" ? "bg-blue-100 text-blue-700" : 
                                      topic.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                      topic.Status == "Revision" ? "bg-yellow-100 text-yellow-700" : "bg-gray-100 text-gray-700")">
                                    @topic.Status
                                </span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Approval Status Timeline -->
        @if (selectedTopic != null)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="font-bold text-gray-800 mb-4">Trạng thái duyệt</h3>
                
                <div class="relative pl-4 border-l-2 border-gray-100 space-y-6">
                    <div class="relative">
                        <div class="absolute -left-[21px] top-1 h-3 w-3 rounded-full border-2 border-green-500 bg-white"></div>
                        <p class="text-xs text-gray-400 mb-1">@(selectedTopic.SubmittedDate?.ToString("dd/MM/yyyy") ?? "--/--/----")</p>
                        <p class="text-sm font-bold text-gray-800">Tạo đề tài</p>
                        <p class="text-xs text-green-600">Hoàn thành</p>
                    </div>
                    
                    <div class="relative @(selectedTopic.Status == "Approved" ? "" : "opacity-50")">
                        <div class="absolute -left-[21px] top-1 h-3 w-3 rounded-full border-2 @(selectedTopic.Status == "Approved" ? "border-green-500" : "border-gray-300") bg-white"></div>
                        <p class="text-xs text-gray-400 mb-1">@(selectedTopic.SubmittedDate?.ToString("dd/MM/yyyy") ?? "--/--/----")</p>
                        <p class="text-sm font-bold text-gray-800">Đã gửi đề tài</p>
                        <p class="text-xs text-green-600">Đã được duyệt tự động</p>
                    </div>
                </div>
            </div>
        }

        <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
            <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                    <p class="font-bold text-blue-800 mb-1 text-sm">Mẹo</p>
                    <p class="text-sm text-blue-600 leading-relaxed">Đảm bảo mô tả đề tài rõ ràng, nêu bật tính mới và ứng dụng thực tiễn để tăng cơ hội được duyệt.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Topic Modal -->
@if (isLeader)
{
    <div id="createTopicModal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-900 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="document.getElementById('createTopicModal').classList.add('hidden')"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="relative inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-xl sm:w-full">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-bold text-gray-900 mb-4" id="modal-title">Tạo đề tài mới</h3>
                    <form asp-action="CreateTopic" method="post" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tên đề tài</label>
                            <input type="text" name="name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50" placeholder="Nhập tên đề tài..." required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Lĩnh vực</label>
                            <select name="field" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50">
                                <option value="Software Engineering">Công nghệ phần mềm</option>
                                <option value="Information Systems">Hệ thống thông tin</option>
                                <option value="Artificial Intelligence">Trí tuệ nhân tạo</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả chi tiết</label>
                            <textarea name="description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50" placeholder="Mô tả mục tiêu, công nghệ sử dụng..."></textarea>
                        </div>
                        <div class="flex justify-end gap-3 mt-6">
                            <button type="button" onclick="document.getElementById('createTopicModal').classList.add('hidden')" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">Hủy</button>
                            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors font-medium shadow-lg shadow-primary/30">Lưu bản nháp</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<!-- Edit Topic Modal -->
@if (selectedTopic != null)
{
    <div id="editTopicModal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-900 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="document.getElementById('editTopicModal').classList.add('hidden')"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="relative inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-xl sm:w-full">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-bold text-gray-900 mb-4" id="modal-title">Chỉnh sửa đề tài</h3>
                    <form asp-action="EditTopic" method="post" class="space-y-4">
                        <input type="hidden" name="topicId" value="@selectedTopic.Id" />
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tên đề tài</label>
                            <input type="text" name="name" value="@selectedTopic.Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Lĩnh vực</label>
                            <select name="field" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50">
                                <option value="Software Engineering" selected="@(selectedTopic.Field == "Software Engineering")">Công nghệ phần mềm</option>
                                <option value="Information Systems" selected="@(selectedTopic.Field == "Information Systems")">Hệ thống thông tin</option>
                                <option value="Artificial Intelligence" selected="@(selectedTopic.Field == "Artificial Intelligence")">Trí tuệ nhân tạo</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Mô tả chi tiết</label>
                            <textarea name="description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50">@selectedTopic.Description</textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Repository Link</label>
                            <input type="url" name="repoLink" value="@selectedTopic.RepoLink" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50" placeholder="https://github.com/...">
                        </div>
                        <div class="flex justify-end gap-3 mt-6">
                            <button type="button" onclick="document.getElementById('editTopicModal').classList.add('hidden')" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">Hủy</button>
                            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
