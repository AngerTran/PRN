<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Capstone Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#f97316',
                        'primary-dark': '#ea580c',
                        'dark-navy': '#0f172a',
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    @using System.Security.Claims
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-100 min-h-screen flex">
    <aside class="w-64 bg-dark-navy text-white min-h-screen fixed left-0 top-0 z-30 flex flex-col justify-between">
        <div>
            <div class="p-6 flex items-center gap-3">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h1 class="font-bold text-lg leading-tight">Capstone</h1>
                    <p class="text-xs text-gray-400">Quản trị</p>
                </div>
            </div>
            <div class="px-6 mb-6">
                <span class="px-3 py-1 bg-primary/20 text-primary text-xs font-semibold rounded-full border border-primary/20">Admin</span>
            </div>
            <nav class="flex-1 px-4 space-y-1">
                @{
                    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                    string NavClass(string action) =>
                        currentAction == action ? "bg-primary text-white shadow-lg shadow-primary/30" : "text-gray-400 hover:bg-white/5 hover:text-white";
                }
                <a asp-controller="Admin" asp-action="Dashboard"
                   class="@NavClass("Dashboard") flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                    </svg>
                    <span class="font-medium">Tổng quan</span>
                </a>
            </nav>
        </div>
        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3 px-2 py-2 rounded-xl hover:bg-white/5 transition-colors">
                <div class="w-10 h-10 bg-gray-600 rounded-full flex items-center justify-center text-white font-bold shrink-0">
                    @{
                        var d = User.Identity?.Name ?? "?";
                        var ini = d.Length > 0 ? d.Substring(0, 1).ToUpper() : "?";
                    }
                    @ini
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium truncate text-white" title="@d">@d</p>
                    <p class="text-xs text-gray-400 truncate">@(User.FindFirstValue(ClaimTypes.Email) ?? User.Identity?.Name)</p>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="shrink-0">
                    <button type="submit" class="p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/10" title="Đăng xuất">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </aside>
    <main class="flex-1 ml-64 p-8 pb-24">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
