<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Capstone Registration System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#f97316',      // Orange 500
                        'primary-dark': '#ea580c', // Orange 600
                        'dark-navy': '#0f172a',    // Slate 900 (Deep Navy)
                        'dark-navy-light': '#1e293b', // Slate 800 (Lighter Navy)
                        'surface': '#ffffff',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; max-width: 100vw; overflow-x: hidden; }
        /* Khi CDN Tailwind lỗi/chậm: ô logo + icon cố định px */
        .auth-layout .icon-box { width: 2.5rem; height: 2.5rem; min-width: 2.5rem; min-height: 2.5rem; box-sizing: border-box; }
        .auth-layout .icon-sm { width: 1.25rem; height: 1.25rem; min-width: 1.25rem; min-height: 1.25rem; max-width: 1.25rem; max-height: 1.25rem; }
        .auth-layout .icon-md { width: 1.5rem; height: 1.5rem; min-width: 1.5rem; min-height: 1.5rem; max-width: 1.5rem; max-height: 1.5rem; }
    </style>
</head>
<body class="auth-layout bg-gray-50 min-h-screen">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
