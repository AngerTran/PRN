<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Capstone System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#f97316',      // Orange 500
                        'primary-dark': '#ea580c', // Orange 600
                        'dark-navy': '#0f172a',    // Slate 900 (Deep Navy)
                        'dark-navy-light': '#1e293b', // Slate 800 (Lighter Navy)
                        'surface': '#ffffff',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    @using System.Security.Claims
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-64 bg-dark-navy text-white min-h-screen fixed left-0 top-0 z-30 flex flex-col justify-between">
        <div>
            <!-- Logo -->
            <div class="p-6 flex items-center gap-3">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    </svg>
                </div>
                <div>
                    <h1 class="font-bold text-lg leading-tight">Capstone</h1>
                    <p class="text-xs text-gray-400">FPT University</p>
                </div>
            </div>

            <!-- Role Badge -->
            <div class="px-6 mb-6">
                <span class="px-3 py-1 bg-purple-500/20 text-purple-300 text-xs font-semibold rounded-full border border-purple-500/20">
                    Hội đồng
                </span>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-4 space-y-1">
                @{
                    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                    
                    string GetActiveClass(string action) => 
                        currentAction == action ? "bg-primary text-white shadow-lg shadow-primary/30" : "text-gray-400 hover:bg-white/5 hover:text-white";
                }

                <a asp-controller="Committee" asp-action="Dashboard" 
                   class="@GetActiveClass("Dashboard") flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                    </svg>
                    <span class="font-medium">Tổng quan</span>
                </a>

                <a asp-controller="Committee" asp-action="Slots" 
                   class="@GetActiveClass("Slots") flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span class="font-medium">Quản lý Slot</span>
                </a>

                <a asp-controller="Committee" asp-action="ManageCommittees" 
                   class="@GetActiveClass("ManageCommittees") flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    <span class="font-medium">Hội đồng</span>
                </a>
            </nav>
        </div>

        <!-- User Profile (Bottom) -->
        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3 px-2 py-2 rounded-xl hover:bg-white/5 transition-colors">
                <div class="w-10 h-10 bg-gray-600 rounded-full flex items-center justify-center text-white font-bold shrink-0">
                    @{
                        var displayName = User.Identity?.Name ?? "?";
                        var initial = displayName.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "?";
                    }
                    @initial
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium truncate text-white" title="@displayName">@displayName</p>
                    <p class="text-xs text-gray-400 truncate">@(User.FindFirstValue(ClaimTypes.Email) ?? User.Identity?.Name)</p>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="shrink-0">
                    <button type="submit" class="p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/10" title="Đăng xuất">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8 pb-12">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
