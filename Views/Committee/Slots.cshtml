@model List<CapstoneReviewTool.Entities.DefenseSlot>
@{
    Layout = "_CommitteeLayout";
    ViewData["Title"] = "Quản lý Slot";
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">Quản lý Slot</h2>
            <p class="text-gray-500 text-sm">Danh sách các slot bảo vệ đã tạo</p>
        </div>
        <a asp-action="CreateSlot" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors text-sm font-semibold flex items-center gap-2 shadow-lg shadow-primary/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Tạo Slot mới
        </a>
    </div>

     @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 text-green-600 p-4 rounded-xl border border-green-100 flex items-center gap-3">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            @TempData["Success"]
        </div>
    }

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Thời gian</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Phòng / Hình thức</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Hội đồng</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Đã đăng ký</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Trạng thái</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Any())
                {
                    @foreach (var slot in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <p class="font-bold text-gray-800">@slot.StartTime.ToString("dd/MM/yyyy")</p>
                                <p class="text-sm text-gray-500">@slot.StartTime.ToString("HH:mm") - @slot.EndTime.ToString("HH:mm")</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="capitalize text-gray-800">@slot.Room</span>
                                <span class="text-xs text-gray-500 block">@slot.Mode</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm font-medium text-gray-800">@(slot.Committee?.Name ?? "Chưa gán")</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="font-medium text-gray-900">@slot.Registrations.Count</span>
                                <span class="text-gray-500">/@slot.MaxGroups</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (slot.Registrations.Count >= slot.MaxGroups)
                                {
                                    <span class="px-2 py-1 bg-red-100 text-red-600 text-xs font-semibold rounded-full">Đã đầy</span>
                                }
                                else
                                {
                                     <span class="px-2 py-1 bg-green-100 text-green-600 text-xs font-semibold rounded-full">Còn chỗ</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="SlotDetails" asp-route-id="@slot.Id" class="text-primary hover:text-primary-dark font-medium text-sm">Quản lý</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-gray-500">Chưa có slot nào. Hãy tạo slot mới.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
