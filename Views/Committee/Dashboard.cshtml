@model CapstoneReviewTool.ViewModels.SystemOverviewViewModel
@{
    Layout = "_CommitteeLayout";
    ViewData["Title"] = "Tổng quan";
}

<div class="space-y-2 mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Tổng quan hệ thống</h1>
    <p class="text-gray-500 text-sm">Cùng bộ số liệu với trang quản trị — cập nhật theo cơ sở dữ liệu thực.</p>
</div>

<partial name="_DashboardSystemStats" model="Model" />

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <a asp-controller="Committee" asp-action="Slots" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition block">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-2">Quản lý slot bảo vệ</h3>
        <p class="text-gray-500 text-sm mb-2">Xem lịch, chi tiết đăng ký, duyệt nhóm</p>
        <span class="text-primary font-medium text-sm">Mở trang slot →</span>
    </a>

    <a asp-controller="Committee" asp-action="ManageCommittees" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition block">
        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-2">Hội đồng</h3>
        <p class="text-gray-500 text-sm mb-2">Tạo hội đồng và thêm thành viên</p>
        <span class="text-primary font-medium text-sm">Quản lý →</span>
    </a>

    <a asp-controller="Committee" asp-action="CreateSlot" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition block">
        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-2">Tạo slot mới</h3>
        <p class="text-gray-500 text-sm mb-2">Thêm ca bảo vệ vào lịch</p>
        <span class="text-primary font-medium text-sm">Tạo slot →</span>
    </a>
</div>
