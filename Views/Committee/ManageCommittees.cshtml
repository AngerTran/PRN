@model List<CapstoneReviewTool.Entities.Committee>
@{
    Layout = "_CommitteeLayout";
    ViewData["Title"] = "Quản lý Hội đồng";
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">Quản lý Hội đồng</h2>
            <p class="text-gray-500 text-sm">Danh sách các hội đồng bảo vệ và thành viên</p>
        </div>
    </div>

    <!-- Create Committee -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h3 class="font-bold text-gray-800 mb-4">Tạo Hội đồng mới</h3>
        <form asp-action="CreateCommittee" method="post" class="flex gap-4">
            <input type="text" name="name" placeholder="Tên hội đồng (VD: Hội đồng 1 (CNPM))" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50" required>
            <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors font-medium">Tạo</button>
        </form>
    </div>

    <!-- List Committees -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        @foreach (var committee in Model)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="font-bold text-lg text-gray-800">@committee.Name</h3>
                    <span class="text-sm text-gray-500">@committee.Members.Count thành viên</span>
                </div>
                
                <div class="mb-4">
                    <p class="text-sm font-medium text-gray-700 mb-2">Thành viên:</p>
                    <ul class="space-y-2">
                        @if (committee.Members.Any())
                        {
                            foreach (var member in committee.Members)
                            {
                                <li class="flex items-center gap-2 text-sm text-gray-600 bg-gray-50 p-2 rounded-lg">
                                    <div class="w-2 h-2 rounded-full bg-green-400"></div>
                                    @member.User?.FullName (@member.User?.Email)
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-sm text-gray-400 italic">Chưa có thành viên</li>
                        }
                    </ul>
                </div>

                <div class="pt-4 border-t border-gray-100">
                    <form asp-action="AddMember" method="post" class="space-y-2">
                        <input type="hidden" name="committeeId" value="@committee.Id" />
                        <select name="userId" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                             <option value="">-- Thêm giảng viên --</option>
                             @if (ViewBag.Users != null)
                             {
                                 foreach (var user in ViewBag.Users)
                                 {
                                     <option value="@user.Id">@user.FullName (@user.Email)</option>
                                 }
                             }
                        </select>
                        <button type="submit" class="w-full px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm font-medium transition-colors">Thêm vào hội đồng</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
